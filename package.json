  "main": "index.js",
  "scripts": {
    "start": "portless run webpack server --mode development",
    "build": "webpack --mode production",
    "test": "node --test",
    "typecheck": "npx tsc --noEmit --allowJs --checkJs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edgonz/caleta.git"
  },
  "bugs": {
    "url": "https://github.com/edgonz/caleta/issues"
  },
  "homepage": "https://github.com/edgonz/caleta#readme",
  "keywords": [
